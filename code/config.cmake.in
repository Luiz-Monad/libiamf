@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Always required
find_dependency(wavwriter REQUIRED)

# Optional features
if(@MULTICHANNEL_BINAURALIZER@)
  find_dependency(iamf2resonance REQUIRED)
endif()

if(@HOA_BINAURALIZER@)
  find_dependency(iamf2bear REQUIRED)
endif()

# Load targets
if(NOT TARGET iamf::iamf)
    include("${CMAKE_CURRENT_LIST_DIR}/iamf-targets.cmake")
endif()

# --- Patch missing configurations (e.g. MinSizeRel, RelWithDebInfo) ---
# If target only exported Debug/Release, reuse Release for the others.
foreach(full_tgt iamf::iamf) # adjust to match what you export
  if(TARGET ${full_tgt})
    # Prefer Release location, otherwise Debug
    get_target_property(rel_loc ${full_tgt} IMPORTED_LOCATION_RELEASE)
    if(NOT rel_loc)
      get_target_property(rel_loc ${full_tgt} IMPORTED_LOCATION_DEBUG)
    endif()
    if(rel_loc)
      foreach(cfg RELWITHDEBINFO MINSIZEREL)
        if(NOT DEFINED IMPORTED_LOCATION_${cfg})
          set_target_properties(${full_tgt} PROPERTIES
            IMPORTED_LOCATION_${cfg} "${rel_loc}"
          )
        endif()
      endforeach()
    endif()
  endif()
endforeach()
