From f62a4a0608a62801d7478053583883104eed5340 Mon Sep 17 00:00:00 2001
From: Luiz Felipe Stangarlin <luizfelipestang@gmail.com>
Date: Thu, 4 Sep 2025 17:24:45 -0500
Subject: [PATCH 1/3] patch: fix cmake

---
 visr_bear/CMakeLists.txt             |  6 ++++--
 visr_bear/cmake/bear-config.cmake.in | 21 +++++++++++++++++++++
 visr_bear/src/CMakeLists.txt         |  6 +++---
 3 files changed, 28 insertions(+), 5 deletions(-)

diff --git a/visr_bear/CMakeLists.txt b/visr_bear/CMakeLists.txt
index 2a0141c..7a934f8 100644
--- a/visr_bear/CMakeLists.txt
+++ b/visr_bear/CMakeLists.txt
@@ -1,4 +1,4 @@
-cmake_minimum_required(VERSION 3.12.0)
+cmake_minimum_required(VERSION 3.31.0)
 
 project(
   bear
@@ -87,7 +87,9 @@ option(BEAR_USE_INTERNAL_LIBEAR
        ON)
 if(NOT BEAR_USE_INTERNAL_LIBEAR)
   find_package(ear REQUIRED)
-  find_package(Eigen3 REQUIRED)
+endif()
+if((NOT BEAR_USE_INTERNAL_LIBEAR) OR (NOT EAR_USE_INTERNAL_EIGEN))
+  find_package(Eigen3 3.4 REQUIRED)
 endif()
 
 find_package(nlohmann_json 3.11.0 REQUIRED)
diff --git a/visr_bear/cmake/bear-config.cmake.in b/visr_bear/cmake/bear-config.cmake.in
index 36e4bb1..afa2d95 100644
--- a/visr_bear/cmake/bear-config.cmake.in
+++ b/visr_bear/cmake/bear-config.cmake.in
@@ -6,3 +6,24 @@ find_package(ear REQUIRED)
 if(NOT TARGET bear::bear)
     include(${CMAKE_CURRENT_LIST_DIR}/bear-targets.cmake)
 endif()
+
+# --- Patch missing configurations (e.g. MinSizeRel, RelWithDebInfo) ---
+# If target only exported Debug/Release, reuse Release for the others.
+foreach(full_tgt bear::bear ear) # adjust to match what you export
+  if(TARGET ${full_tgt})
+    # Prefer Release location, otherwise Debug
+    get_target_property(rel_loc ${full_tgt} IMPORTED_LOCATION_RELEASE)
+    if(NOT rel_loc)
+      get_target_property(rel_loc ${full_tgt} IMPORTED_LOCATION_DEBUG)
+    endif()
+    if(rel_loc)
+      foreach(cfg RELWITHDEBINFO MINSIZEREL)
+        if(NOT DEFINED IMPORTED_LOCATION_${cfg})
+          set_target_properties(${full_tgt} PROPERTIES
+            IMPORTED_LOCATION_${cfg} "${rel_loc}"
+          )
+        endif()
+      endforeach()
+    endif()
+  endif()
+endforeach()
diff --git a/visr_bear/src/CMakeLists.txt b/visr_bear/src/CMakeLists.txt
index 0287a3b..591c526 100644
--- a/visr_bear/src/CMakeLists.txt
+++ b/visr_bear/src/CMakeLists.txt
@@ -111,14 +111,14 @@ if(BEAR_PACKAGE_AND_INSTALL)
     EXPORT bear-targets
     FILE bear-targets.cmake
     NAMESPACE bear::
-    DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/bear)
+    DESTINATION ${CMAKE_INSTALL_PREFIX}/cmake)
 
   include(CMakePackageConfigHelpers)
 
   configure_package_config_file(
     ${CMAKE_SOURCE_DIR}/cmake/bear-config.cmake.in
     ${CMAKE_BINARY_DIR}/cmake/bear-config.cmake
-    INSTALL_DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/bear)
+    INSTALL_DESTINATION ${CMAKE_INSTALL_PREFIX}/cmake)
 
   write_basic_package_version_file(
     ${CMAKE_BINARY_DIR}/cmake/bear-config-version.cmake
@@ -127,5 +127,5 @@ if(BEAR_PACKAGE_AND_INSTALL)
 
   install(FILES ${CMAKE_BINARY_DIR}/cmake/bear-config.cmake
                 ${CMAKE_BINARY_DIR}/cmake/bear-config-version.cmake
-          DESTINATION ${CMAKE_INSTALL_LIBDIR}/cmake/bear)
+          DESTINATION ${CMAKE_INSTALL_PREFIX}/cmake)
 endif()
-- 
