diff --git a/resonance_audio/ResonanceAudio-config.cmake.in b/resonance_audio/ResonanceAudio-config.cmake.in
new file mode 100644
index 0000000..d667f05
--- /dev/null
+++ b/resonance_audio/ResonanceAudio-config.cmake.in
@@ -0,0 +1,33 @@
+@PACKAGE_INIT@
+
+include("${CMAKE_CURRENT_LIST_DIR}/ResonanceAudioTargets.cmake")
+
+set( RA_TARGETS @RA_TARGETS@ )
+
+foreach(_target ${RA_TARGETS})
+  check_required_components(${_target})
+endforeach()
+
+# --- Patch missing configurations (e.g. MinSizeRel, RelWithDebInfo) ---
+# If target only exported Debug/Release, reuse Release for the others.
+foreach(tgt ResonanceAudio)
+  foreach(var_suffix Static Shared) # adjust to match what you export
+    set(full_tgt ResonanceAudio::${tgt}${var_suffix})
+    if(TARGET ${full_tgt})
+      # Prefer Release location, otherwise Debug
+      get_target_property(rel_loc ${full_tgt} IMPORTED_LOCATION_RELEASE)
+      if(NOT rel_loc)
+        get_target_property(rel_loc ${full_tgt} IMPORTED_LOCATION_DEBUG)
+      endif()
+      if(rel_loc)
+        foreach(cfg RELWITHDEBINFO MINSIZEREL)
+          if(NOT DEFINED IMPORTED_LOCATION_${cfg})
+            set_target_properties(${full_tgt} PROPERTIES
+              IMPORTED_LOCATION_${cfg} "${rel_loc}"
+            )
+          endif()
+        endforeach()
+      endif()
+    endif()
+  endforeach()
+endforeach()
