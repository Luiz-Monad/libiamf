From 027ca57ac207d2ac2410deb4494fc7917a444583 Mon Sep 17 00:00:00 2001
From: Luiz Felipe Stangarlin <luizfelipestang@gmail.com>
Date: Thu, 4 Sep 2025 17:24:14 -0500
Subject: [PATCH 2/2] patch: fix cmake

---
 3rd/ffts/CMakeLists.txt     |  4 ++--
 3rd/kissfft/CMakeLists.txt  |  2 +-
 3rd/pybind11/CMakeLists.txt | 11 +----------
 CMakeLists.txt              | 21 +++++++--------------
 src/CMakeLists.txt          | 12 ++++--------
 src/libvisr/CMakeLists.txt  |  4 ++--
 src/visr-config.cmake.in    | 34 +++++++++++++++++++++++++++-------
 7 files changed, 44 insertions(+), 44 deletions(-)

diff --git a/3rd/ffts/CMakeLists.txt b/3rd/ffts/CMakeLists.txt
index 1ca77d2..1af7f31 100644
--- a/3rd/ffts/CMakeLists.txt
+++ b/3rd/ffts/CMakeLists.txt
@@ -1,4 +1,4 @@
-cmake_minimum_required(VERSION 2.8.12 FATAL_ERROR)
+cmake_minimum_required(VERSION 3.31.0 FATAL_ERROR)
 
 project(ffts C ASM)
 
@@ -534,7 +534,7 @@ if( ENABLE_STATIC )
   endif( WIN32 )
   set_target_properties( ffts_static PROPERTIES
     ARCHIVE_OUTPUT_NAME ffts
-    ARCHIVE_OUTPUT_DIRECTORY ${CMAKE_BINARY_DIR}/3rd
+    ARCHIVE_OUTPUT_DIRECTORY ${CMAKE_BINARY_DIR}/lib
   )
   install(TARGETS ffts_static
           EXPORT VISR_3rd_party_static_exports
diff --git a/3rd/kissfft/CMakeLists.txt b/3rd/kissfft/CMakeLists.txt
index 76731bf..b743049 100644
--- a/3rd/kissfft/CMakeLists.txt
+++ b/3rd/kissfft/CMakeLists.txt
@@ -1,4 +1,4 @@
-cmake_minimum_required( VERSION 3.3.0 )
+cmake_minimum_required( VERSION 3.31.0 )
 
 project( kissFFT LANGUAGES C )
 
diff --git a/3rd/pybind11/CMakeLists.txt b/3rd/pybind11/CMakeLists.txt
index 87ec103..fa29d76 100644
--- a/3rd/pybind11/CMakeLists.txt
+++ b/3rd/pybind11/CMakeLists.txt
@@ -5,16 +5,7 @@
 # All rights reserved. Use of this source code is governed by a
 # BSD-style license that can be found in the LICENSE file.
 
-cmake_minimum_required(VERSION 3.5)
-
-# The `cmake_minimum_required(VERSION 3.5...3.26)` syntax does not work with
-# some versions of VS that have a patched CMake 3.11. This forces us to emulate
-# the behavior using the following workaround:
-if(${CMAKE_VERSION} VERSION_LESS 3.26)
-  cmake_policy(VERSION ${CMAKE_MAJOR_VERSION}.${CMAKE_MINOR_VERSION})
-else()
-  cmake_policy(VERSION 3.26)
-endif()
+cmake_minimum_required(VERSION 3.31.0)
 
 # Avoid infinite recursion if tests include this as a subdirectory
 if(DEFINED PYBIND11_MASTER_PROJECT)
diff --git a/CMakeLists.txt b/CMakeLists.txt
index 7b94ca7..facd92a 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -5,7 +5,7 @@
 # 3.0.0+ needed for export(EXPORT) command in src/CMakeLists.txt
 # >= 3.1 for CMAKE_CXX_STANDARD
 # 3.3 for IN_LIST operator in if() conditions
-CMAKE_MINIMUM_REQUIRED (VERSION 3.3.0)
+CMAKE_MINIMUM_REQUIRED (VERSION 3.31.0)
 
 # Avoid warnings about the CXX_VISIBILITY_PRESET set for all target types.
 if( POLICY CMP0063 ) # (only if the CMake version supports this policy
@@ -372,18 +372,11 @@ endif( VISR_SYSTEM_NAME MATCHES "Linux" )
 # Installation destination for third-party libraries: shared libs (incl. the DLL part and
 # import lib on Windows) and static libs.
 # This will be appended to the installation prefix.
-if( VISR_SYSTEM_NAME MATCHES Linux )
-  # Installed files go into the /usr tree, so we must use the standard location for the libs.
-  set( THIRDPARTY_LIBRARY_INSTALL_DIRECTORY lib )
-  set( THIRDPARTY_RUNTIME_INSTALL_DIRECTORY lib)
-  set( THIRDPARTY_ARCHIVE_INSTALL_DIRECTORY lib )
-else()
-  # TODO: Decide whether this should go into lib/ on Windows to avoid an
-  # additional entry to be added to %PATH%
-  set( THIRDPARTY_LIBRARY_INSTALL_DIRECTORY 3rd )
-  set( THIRDPARTY_RUNTIME_INSTALL_DIRECTORY 3rd )
-  set( THIRDPARTY_ARCHIVE_INSTALL_DIRECTORY 3rd )
-endif( VISR_SYSTEM_NAME MATCHES Linux )
+
+# Installed files go into the /usr tree, so we must use the standard location for the libs.
+set( THIRDPARTY_LIBRARY_INSTALL_DIRECTORY lib )
+set( THIRDPARTY_RUNTIME_INSTALL_DIRECTORY lib )
+set( THIRDPARTY_ARCHIVE_INSTALL_DIRECTORY lib )
 
 ###########################################################
 # Support for 3rd-party libraries.
@@ -464,7 +457,7 @@ option( Boost_USE_STATIC_LIBS "Whether to use static or shared boost libraries."
 # Define the boost libraries that will be needed in deployed installations.
 # In boost 1.59 on Windows, chrono is an implicit dependency of boost_thread. So in order to locate the runtime DLL for packaging, we mus add this library here.
 # Note that unit_test_framework is excluded here because it's only used in local builds.
-set( VISR_BOOST_INSTALL_LIBRARIES chrono date_time filesystem program_options system regex timer )
+set( VISR_BOOST_INSTALL_LIBRARIES asio chrono date_time filesystem program_options system regex timer format )
 if( NOT BUILD_DISABLE_THREADS )
   list( APPEND VISR_BOOST_INSTALL_LIBRARIES thread atomic)
 endif( NOT BUILD_DISABLE_THREADS )
diff --git a/src/CMakeLists.txt b/src/CMakeLists.txt
index a1fd323..b4a2a80 100644
--- a/src/CMakeLists.txt
+++ b/src/CMakeLists.txt
@@ -1,14 +1,8 @@
 # Copyright Institute of Sound and Vibration Research - All rights reserved
 
 # Set the installation directory for the export and version files
-if( VISR_SYSTEM_NAME MATCHES "Linux" )
-  # On  Linux, there's a predefined directory structure under /usr/lib
-  set( VISR_INSTALL_EXPORT_CONFIG_DIRECTORY lib/cmake/visr )
-else( VISR_SYSTEM_NAME MATCHES "Linux" )
-  # On Windows and MacOS, install it in a cmake/ directory within the application's install directory,
-  # e.g. c:\Program Files\VISR-X.X.X/cmake or /Applications/VISR-X.X.X/cmake
-  set( VISR_INSTALL_EXPORT_CONFIG_DIRECTORY cmake )
-endif( VISR_SYSTEM_NAME MATCHES "Linux" )
+include(GNUInstallDirs)
+set( VISR_INSTALL_EXPORT_CONFIG_DIRECTORY ${CMAKE_INSTALL_PREFIX}/cmake )
 
 # Location of export files in build tree
 set( VISR_BUILD_EXPORT_CONFIG_DIRECTORY ${CMAKE_BINARY_DIR}/cmake )
@@ -117,6 +111,8 @@ endif( BUILD_PYTHON_BINDINGS )
 # This will be written into the visr-config.cmake file.
 set( VISR_EXPORTED_COMPONENTS )
 
+set( VISR_3RD_PARTY_COMPONENTS ffts kissfft )
+
 if( BUILD_INSTALL_STATIC_LIBRARIES OR BUILD_INSTALL_STATIC_PIC_LIBRARIES )
   ## Component for 3rd-static components provided by VISR
   # These are needed to link dependent projects against static VISR libraries.
diff --git a/src/libvisr/CMakeLists.txt b/src/libvisr/CMakeLists.txt
index 37fa923..a3d0fc3 100644
--- a/src/libvisr/CMakeLists.txt
+++ b/src/libvisr/CMakeLists.txt
@@ -148,9 +148,9 @@ if( BUILD_INSTALL_STATIC_PIC_LIBRARIES )
 endif( BUILD_INSTALL_STATIC_PIC_LIBRARIES )
 
 # TODO: Try to install the detail/ headers as part of the ordinary PUBLIC_HEADER installation.
-if( BUILD_INSTALL_SHARED_LIBRARIES OR BUILD_INSTALL_SHARED_LIBRARIES )
+if( BUILD_INSTALL_SHARED_LIBRARIES OR BUILD_INSTALL_STATIC_LIBRARIES )
   install( FILES ${PUBLIC_HEADERS_DETAIL} DESTINATION include/visr/libvisr/detail COMPONENT development_files )
-endif( BUILD_INSTALL_SHARED_LIBRARIES OR BUILD_INSTALL_SHARED_LIBRARIES )
+endif( BUILD_INSTALL_SHARED_LIBRARIES OR BUILD_INSTALL_STATIC_LIBRARIES )
 
 if( BUILD_TESTING )
   add_subdirectory( test )
diff --git a/src/visr-config.cmake.in b/src/visr-config.cmake.in
index 0fec2d4..daf6c27 100644
--- a/src/visr-config.cmake.in
+++ b/src/visr-config.cmake.in
@@ -7,6 +7,7 @@ else( POLICY CMP0057 )
 endif( POLICY CMP0057 )
 
 set( VISR_EXPORTED_COMPONENTS @VISR_EXPORTED_COMPONENTS@ )
+set( VISR_3RD_PARTY_COMPONENTS @VISR_3RD_PARTY_COMPONENTS@ )
 
 # Require all components if no components are specified in find_package( VISR )
 if(NOT VISR_FIND_COMPONENTS)
@@ -77,17 +78,12 @@ if( (static_libraries IN_LIST VISR_FIND_COMPONENTS_ADJUSTED )
   # module search path.
   list( APPEND CMAKE_MODULE_PATH ${CMAKE_CURRENT_LIST_DIR} )
 
-  # Append the locations of the 3rd-party library files provided with VISR
-  # so that importing projects can use them.
-  list( APPEND CMAKE_INCLUDE_PATH @PACKAGE_VISR_3RD_PARTY_DIR@/include )
-  list( APPEND CMAKE_LIBRARY_PATH @PACKAGE_VISR_3RD_PARTY_DIR@ )
-
   if( ${VISR_USE_SNDFILE_LIBRARY} )
     find_dependency( SndFile )
   endif( ${VISR_USE_SNDFILE_LIBRARY} )
-  if( VISR_AUDIOINTERFACES_PORTAUDIO )
+  if( ${VISR_AUDIOINTERFACES_PORTAUDIO} )
     find_dependency( Portaudio )
-  endif( VISR_AUDIOINTERFACES_PORTAUDIO )
+  endif( ${VISR_AUDIOINTERFACES_PORTAUDIO} )
 
   # Note: we do not list the dependencies SndFile, Portaudio, Jack
   # here, because they are non-standard and cannot imported through
@@ -109,3 +105,27 @@ foreach( lib ${VISR_LIBRARIES} )
     check_required_components( ${lib}_static_pic )
   endif( static_pic_libraries IN_LIST VISR_FIND_COMPONENTS_ADJUSTED )
 endforeach( lib ${VISR_LIBRARIES} )
+
+# --- Patch missing configurations (e.g. MinSizeRel, RelWithDebInfo) ---
+# If target only exported Debug/Release, reuse Release for the others.
+foreach(tgt ${VISR_LIBRARIES} ${VISR_3RD_PARTY_COMPONENTS})
+  foreach(var_suffix _static _static_pic _shared) # adjust to match what you export
+    set(full_tgt VISR::${tgt}${var_suffix})
+    if(TARGET ${full_tgt})
+      # Prefer Release location, otherwise Debug
+      get_target_property(rel_loc ${full_tgt} IMPORTED_LOCATION_RELEASE)
+      if(NOT rel_loc)
+        get_target_property(rel_loc ${full_tgt} IMPORTED_LOCATION_DEBUG)
+      endif()
+      if(rel_loc)
+        foreach(cfg RELWITHDEBINFO MINSIZEREL)
+          if(NOT DEFINED IMPORTED_LOCATION_${cfg})
+            set_target_properties(${full_tgt} PROPERTIES
+              IMPORTED_LOCATION_${cfg} "${rel_loc}"
+            )
+          endif()
+        endforeach()
+      endif()
+    endif()
+  endforeach()
+endforeach()
-- 
2.46.0.windows.1

